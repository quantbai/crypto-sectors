Thumbs.db

# Notebooks
.ipynb_checkpoints/

# Agent / tooling state (gstack, Claude Code, etc.)
.gstack/
.claude/

# Internal working artifacts — design docs, working plans, ad-hoc notes.
# These are not part of the published product. Public methodology / decisions
# live in methodology.md / decisions/ — committed and audited.
plans/

# Reference material & scratch — third-party vendor docs and an imported
# alpha-research workspace. Local-only, never published (contains private signal).
ref/

# Data caches and per-run outputs — regenerated locally, not part of the build.
# The published artifacts — classification/wide/*.{csv,parquet} and
# classification/long/*.{csv,parquet} — ARE committed and regenerated by
# scripts/build_matrices.py; CI asserts they stay in sync.
# (gitignore note: keep comments on their own line — a trailing inline '#'
#  becomes part of the pattern and silently disables the rule.)
data/raw_ohlcv/
data/coverage.csv
data/descriptions.MISSING.txt

# Dated audit reports from audit_universe.py — accumulate across runs;
# archive the ones that informed a published universe change to decisions/
# and let the rest stay local.
validation/universe_audit_*.md
validation/universe_audit_*.csv
